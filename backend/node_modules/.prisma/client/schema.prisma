generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  name           String
  role           Role            @default(USER)
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Work {
  id          String      @id @default(uuid())
  name        String
  address     String
  description String?
  status      String      @default("IN_PROGRESS")
  warehouses  Warehouse[]
  diaries     WorkDiary[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Warehouse {
  id             String          @id @default(uuid())
  name           String
  workId         String
  work           Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  stocks         Stock[]
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Material {
  id             String          @id @default(uuid())
  name           String
  unit           String
  description    String?
  stocks         Stock[]
  stockMovements StockMovement[]
  materialUsages MaterialUsage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Stock {
  id          String    @id @default(uuid())
  quantity    Float     @default(0)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, materialId])
}

model StockMovement {
  id          String    @id @default(uuid())
  type        String // "add", "remove", "set"
  quantity    Float
  description String?
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model Employee {
  id           String       @id @default(uuid())
  name         String
  jobTitle     String
  dailyRate    Float
  laborEntries LaborEntry[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model WorkDiary {
  id             String          @id @default(uuid())
  workId         String
  work           Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  date           DateTime
  laborEntries   LaborEntry[]
  materialUsages MaterialUsage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([workId, date])
}

model LaborEntry {
  id          String    @id @default(uuid())
  workDiaryId String
  workDiary   WorkDiary @relation(fields: [workDiaryId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cost        Float // The daily rate at the time of entry
  createdAt   DateTime  @default(now())
}

model MaterialUsage {
  id          String    @id @default(uuid())
  workDiaryId String
  workDiary   WorkDiary @relation(fields: [workDiaryId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  quantity    Float
  unitPrice   Float // The price at the time of entry
  createdAt   DateTime  @default(now())
}
